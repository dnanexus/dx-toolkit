// Pipeline that requires Docker (via process.container) but does NOT enable it by default.
// Docker lives inside the profiles block — it must be explicitly activated via -profile docker
// or injected via dx_docker.config. Without either, Nextflow tries to run natively → crash.
process.container = 'quay.io/nextflow/bash'

profiles {
    docker {
        docker.enabled = true
    }
}
